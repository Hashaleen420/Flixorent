<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#00000000">

    <LinearLayout
        android:id="@+id/exo_center_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/exo_rew"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_tv_focus"
            android:src="@android:drawable/ic_media_rew"
            android:contentDescription="Rewind"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusRight="@id/exo_play_pause" />

        <ImageButton
            android:id="@+id/exo_play_pause"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_tv_focus"
            android:src="@android:drawable/ic_media_play"
            android:contentDescription="Play or Pause"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusLeft="@id/exo_rew"
            android:nextFocusRight="@id/exo_ffwd" />

        <ImageButton
            android:id="@+id/exo_ffwd"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_tv_focus"
            android:src="@android:drawable/ic_media_ff"
            android:contentDescription="Fast Forward"
            android:focusable="true"
            android:clickable="true"
            android:nextFocusLeft="@id/exo_play_pause" />
    </LinearLayout>

    <androidx.media3.ui.DefaultTimeBar
        android:id="@+id/exo_progress"
        android:layout_width="match_parent"
        android:layout_height="26dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:focusable="true"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>